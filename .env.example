# =========================================================================
# YUVAHUB - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to '.env' and fill in the values for local development.
# =========================================================================

# -------------------------------------------------------------------------
# MongoDB Configuration
# -------------------------------------------------------------------------
# Required for persistent data storage (opportunities, user profiles, posts).
# To run locally:
# 1. Sign up for a free MongoDB Atlas cluster at https://www.mongodb.com/cloud/atlas
# 2. Or install MongoDB Community Edition locally (e.g., mongodb://localhost:27017/yuvahub).
# If left blank or connection fails, the app runs in "Offline Mock Mode" using static curated data.
MONGODB_URI=mongodb://localhost:27017/yuvahub
MONGODB_DB_NAME=yuvahub

# -------------------------------------------------------------------------
# Google Gemini AI API Configuration
# -------------------------------------------------------------------------
# Required for AI features (Resume Review, Cover Letter Generation, AI Mentor chat).
# Get a FREE API key from Google AI Studio in 1 click:
# https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# -------------------------------------------------------------------------
# Application URLs & CORS Configuration
# -------------------------------------------------------------------------
# APP_URL: The self-referential URL of the hosting environment.
# For local development: http://localhost:5173
APP_URL=http://localhost:5173

# FRONTEND_URL: Used to restrict CORS request access.
# MUST match your local frontend port during development to allow API requests.
# Set to 'http://localhost:5173' for local dev, or comment out to allow all origins.
FRONTEND_URL=http://localhost:5173

# -------------------------------------------------------------------------
# Redis Configuration (Optional)
# -------------------------------------------------------------------------
# Required for distributed token-bucket rate limiting on AI routes.
# If you don't have Redis running locally, comment this out.
# Bypassing Redis runs the app in "fail-open" mode (unlimited requests).
# Get a free cloud Redis URL instantly at https://upstash.com/
# REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------------------
# Firebase Authentication Setup Note
# -------------------------------------------------------------------------
# Firebase configuration is loaded dynamically from the root configuration file:
# 'firebase-applet-config.json' (make sure this file exists in your root folder).
#
# IMPORTANT FOR LOCAL SIGN-IN (authorized-domain error):
# If you get a 'Firebase: Error (auth/unauthorized-domain)' in your browser console,
# you must authorize 'localhost' in your Firebase console:
# Go to: Firebase Console -> Authentication -> Settings -> Authorized domains -> Add 'localhost'

# -------------------------------------------------------------------------
# EmailJS Configuration (Optional)
# -------------------------------------------------------------------------
# Required for sending automated email confirmations/notifications.
# Create a free account at https://www.emailjs.com/ and obtain these credentials.
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
